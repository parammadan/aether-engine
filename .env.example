# Copy to .env and fill in real values. .env is gitignored — never commit it.
# Q1 needs no secrets; these are placeholders for later quarters.

# OpenSky Network (public flight telemetry). Anonymous access works but is rate-limited;
# a free account raises the limit. Q1 ingestion (later this quarter) will read these.
OPENSKY_USERNAME=your-opensky-username
OPENSKY_PASSWORD=your-opensky-password

# Later phases only (do NOT wire these up in Q1):
# HF_TOKEN=your-huggingface-token          # ONNX model download (Q4)
# AWS_ACCESS_KEY_ID=                        # if/when deployed to AWS
# AWS_SECRET_ACCESS_KEY=
