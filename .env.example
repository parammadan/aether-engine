# Copy to .env and fill in real values. .env is gitignored — never commit it.
# Nothing here is required: the engine runs without secrets.

# OpenSky Network (public flight telemetry). Anonymous access works but is rate-limited;
# a free account raises the limit. The ingestion loop reads these when set.
OPENSKY_USERNAME=your-opensky-username
OPENSKY_PASSWORD=your-opensky-password

# Optional:
# HF_TOKEN=your-huggingface-token          # only if a model host requires auth
# AWS_ACCESS_KEY_ID=                        # if/when deployed to AWS
# AWS_SECRET_ACCESS_KEY=
